{
  "manifest_version": 3,
  "name": "INTERNET.COM",
  "version": "1.0",
  "description": "Bookmark manager",
  "action": {
    "default_popup": "index.html",
    "default_icon": "icon.svg"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "storage"],
  "commands": {
    "open-popup": {
      "suggested_key": { "default": "Alt+Shift+I", "mac": "Alt+Shift+I" },
      "description": "Ouvrir INTERNET.COM"
    }
  },
  "host_permissions": ["https://vianneygenin.github.io/*"],
  "content_scripts": [{
    "matches": ["https://vianneygenin.github.io/internet.com/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }]
}
